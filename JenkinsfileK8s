pipeline {
    agent any

    environment {
        ANSIBLE_HOST_KEY_CHECKING = "False"

        // AWS EKS Configuration
        AWS_REGION = 'eu-central-1'
        EKS_CLUSTER_NAME = 'test-cluster-1'
        AWS_ACCOUNT_ID = '271758791556'
        ECR_REGISTRY = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        ECR_REPOSITORY = 'orderbook-tomcat'
        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    tools {
        maven 'MAVEN_HOME'
        jdk 'JAVA_HOME'
    }

    stages {
        stage('Checkout') {
            steps {
                git url: 'https://github.com/theacademy/order-book-demo'
            }
        }

        stage('Compile') {
            steps {
                echo 'compiling..'
                sh 'mvn compile'
            }
        }

        stage('Code Review (PMD)') {
            steps {
                echo 'codereview..'
                sh 'mvn pmd:pmd'
            }
            post {
                success {
                    recordIssues enabledForFailure: true, tool: pmdParser(pattern: '**/target/pmd.xml')
                }
            }
        }

        stage('Test with Clover') {
            steps {
                echo 'running tests with clover..'
                sh 'mvn test -Pcoverage'
                sh 'mvn clover:clover clover:aggregate -Pcoverage'
            }
        }

        stage('Publish Clover Report') {
            steps {
                clover(
                    cloverReportDir: 'target/site/clover',
                    cloverReportFileName: 'clover.xml',
                    healthyTarget: [methodCoverage: 70, conditionalCoverage: 80, statementCoverage: 80],
                    unhealthyTarget: [methodCoverage: 50, conditionalCoverage: 50, statementCoverage: 50],
                    failingTarget: [methodCoverage: 0, conditionalCoverage: 0, statementCoverage: 0]
                )
            }
        }

        stage('Package') {
            steps {
                echo 'packaging..'
                sh 'mvn package'
            }
        }

        stage('Create ECR Repository') {
            steps {
                withAWS(credentials: 'aws-credentials', region: 'eu-central-1') {
                    sh """
                        aws ecr describe-repositories --repository-names ${ECR_REPOSITORY} || \
                        aws ecr create-repository --repository-name ${ECR_REPOSITORY}
                    """
                }
            }
        }

        stage('Build and Push Docker Image') {
            steps {
                withAWS(credentials: 'aws-credentials', region: 'eu-central-1') {
                    sh """
                        # Login to ECR
                        aws ecr get-login-password | \
                        docker login --username AWS --password-stdin ${ECR_REGISTRY}

                        # Build and tag image
                        docker build --file Dockerfile \
                            --tag ${ECR_REGISTRY}/${ECR_REPOSITORY}:${IMAGE_TAG} \
                            --tag ${ECR_REGISTRY}/${ECR_REPOSITORY}:latest .

                        # Push to ECR
                        docker push ${ECR_REGISTRY}/${ECR_REPOSITORY}:${IMAGE_TAG}
                        docker push ${ECR_REGISTRY}/${ECR_REPOSITORY}:latest
                    """
                }
            }
        }

        stage('Deploy to EKS') {
            steps {
                withAWS(credentials: 'aws-credentials', region: 'eu-central-1') {
                    sh """
                        # Configure kubectl
                        aws eks update-kubeconfig --region ${AWS_REGION} --name ${EKS_CLUSTER_NAME}

                        # Create namespace
                        kubectl create namespace qa --dry-run=client -o yaml | kubectl apply -f -

                        # Create ECR pull secret
                        kubectl delete secret ecr-pull-secret -n qa --ignore-not-found
                        kubectl create secret docker-registry ecr-pull-secret \
                            --docker-server=${ECR_REGISTRY} \
                            --docker-username=AWS \
                            --docker-password=\$(aws ecr get-login-password) \
                            --namespace qa

                        # Deploy application with same configuration as working Ansible deployment
                        kubectl apply -f - << 'EOF'
apiVersion: apps/v1
kind: Deployment
metadata:
  name: orderbook
  namespace: qa
  labels:
    app: orderbook
    build: ${BUILD_NUMBER}
spec:
  replicas: 2
  selector:
    matchLabels:
      app: orderbook
  template:
    metadata:
      labels:
        app: orderbook
        build: ${BUILD_NUMBER}
      annotations:
        prometheus.io/scrape: "true"
        prometheus.io/port: "8085"
        prometheus.io/path: "/actuator/prometheus"
    spec:
      imagePullSecrets:
      - name: ecr-pull-secret
      containers:
      - name: orderbook
        image: ${ECR_REGISTRY}/${ECR_REPOSITORY}:${IMAGE_TAG}
        ports:
        - containerPort: 8085
          name: http
        env:
        - name: MANAGEMENT_METRICS_TAGS_APPLICATION
          value: "orderbook"
        - name: MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE
          value: "prometheus,health,info"
        - name: BUILD_NUMBER
          value: "${BUILD_NUMBER}"
        - name: SPRING_PROFILES_ACTIVE
          value: "production"
        - name: SERVER_PORT
          value: "8085"
        resources:
          requests:
            memory: "256Mi"
            cpu: "100m"
          limits:
            memory: "512Mi"
            cpu: "300m"
        livenessProbe:
          httpGet:
            path: /actuator/health
            port: 8085
          initialDelaySeconds: 30
          periodSeconds: 10
        readinessProbe:
          httpGet:
            path: /actuator/health
            port: 8085
          initialDelaySeconds: 30
          periodSeconds: 10
---
apiVersion: v1
kind: Service
metadata:
  name: orderbook
  namespace: qa
  labels:
    app: orderbook
  annotations:
    prometheus.io/scrape: "true"
    prometheus.io/port: "8085"
    prometheus.io/path: "/actuator/prometheus"
spec:
  selector:
    app: orderbook
  type: LoadBalancer
  ports:
  - name: http
    port: 80
    targetPort: 8085
  - name: metrics
    port: 8085
    targetPort: 8085
EOF

                        # Wait for rollout
                        kubectl rollout status deployment/orderbook -n qa --timeout=3m
                    """
                }
            }
        }

        stage('Verify Deployment') {
            steps {
                withAWS(credentials: 'aws-credentials', region: 'eu-central-1') {
                    sh """
                        echo "📊 Deployment Status:"
                        kubectl get pods -n qa -l app=orderbook

                        echo -e "\n🌐 Service Details:"
                        kubectl get svc -n qa orderbook

                        echo -e "\n⏳ Getting LoadBalancer URL..."
                        sleep 10
                        LB_URL=\$(kubectl get svc -n qa orderbook -o jsonpath='{.status.loadBalancer.ingress[0].hostname}' 2>/dev/null)
                        if [ -n "\$LB_URL" ]; then
                            echo "✅ Application URL: http://\$LB_URL"
                            echo "   Actuator Health: http://\$LB_URL/actuator/health"
                            echo "   Prometheus Metrics: http://\$LB_URL/actuator/prometheus"
                        else
                            echo "⏳ LoadBalancer still provisioning..."
                        fi
                    """
                }
            }
        }
    }

    post {
        success {
            echo '✅ Deployment to EKS successful!'
            script {
                // Send notification with app URL
                LB_URL = sh(
                    script: "kubectl get svc -n qa orderbook -o jsonpath='{.status.loadBalancer.ingress[0].hostname}' 2>/dev/null || echo 'Provisioning'",
                    returnStdout: true
                ).trim()
                echo "Application will be available at: http://${LB_URL}"
                echo "Health check: http://${LB_URL}/actuator/health"
            }
        }
        failure {
            echo '❌ Deployment failed! Check logs:'
            sh '''
                echo "--- Recent Pod Events ---"
                kubectl describe pods -n qa -l app=orderbook | grep -A20 Events

                echo -e "\n--- Pod Logs ---"
                kubectl logs -n qa -l app=orderbook --tail=50
            '''
        }
        always {
            cleanWs()
        }
    }
}