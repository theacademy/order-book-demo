pipeline {
    agent any

    environment {
        ANSIBLE_HOST_KEY_CHECKING = "False"

        // AWS EKS Configuration
        AWS_REGION = 'eu-central-1'
        EKS_CLUSTER_NAME = 'test-cluster-1'
        AWS_ACCOUNT_ID = '271758791556'
        ECR_REGISTRY = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        ECR_REPOSITORY = 'orderbook-tomcat'
        IMAGE_TAG = "${BUILD_NUMBER}"

        // App Configuration
        APP_PORT = '8085'
    }

    tools {
        maven 'MAVEN_HOME'
        jdk 'JAVA_HOME'
    }

    stages {
        stage('Checkout') {
            steps {
                git url: 'https://github.com/theacademy/order-book-demo'
            }
        }

        stage('Compile') {
            steps {
                sh 'mvn compile'
            }
        }

        stage('Code Review (PMD)') {
            steps {
                sh 'mvn pmd:pmd'
            }
            post {
                success {
                    recordIssues enabledForFailure: true, tool: pmdParser(pattern: '**/target/pmd.xml')
                }
            }
        }

        stage('Test with Clover') {
            steps {
                sh 'mvn test -Pcoverage'
                sh 'mvn clover:clover clover:aggregate -Pcoverage'
            }
        }

        stage('Publish Clover Report') {
            steps {
                clover(
                    cloverReportDir: 'target/site/clover',
                    cloverReportFileName: 'clover.xml',
                    healthyTarget: [methodCoverage: 70, conditionalCoverage: 80, statementCoverage: 80],
                    unhealthyTarget: [methodCoverage: 50, conditionalCoverage: 50, statementCoverage: 50],
                    failingTarget: [methodCoverage: 0, conditionalCoverage: 0, statementCoverage: 0]
                )
            }
        }

        stage('Package') {
            steps {
                sh 'mvn package'
            }
        }

        stage('Create and Push to ECR') {
            steps {
                withAWS(credentials: 'aws-credentials', region: 'eu-central-1') {
                    sh """
                        # Create repository if it doesn't exist
                        aws ecr describe-repositories --repository-names ${ECR_REPOSITORY} || \
                        aws ecr create-repository --repository-name ${ECR_REPOSITORY}

                        # Login to ECR
                        aws ecr get-login-password | \
                        docker login --username AWS --password-stdin ${ECR_REGISTRY}

                        # Build and push image
                        docker build --file Dockerfile \
                            --tag ${ECR_REGISTRY}/${ECR_REPOSITORY}:${IMAGE_TAG} \
                            --tag ${ECR_REGISTRY}/${ECR_REPOSITORY}:latest .

                        docker push ${ECR_REGISTRY}/${ECR_REPOSITORY}:${IMAGE_TAG}
                        docker push ${ECR_REGISTRY}/${ECR_REPOSITORY}:latest
                    """
                }
            }
        }

        stage('Deploy to EKS') {
            steps {
                withAWS(credentials: 'aws-credentials', region: 'eu-central-1') {
                    sh """
                        # Configure kubectl
                        aws eks update-kubeconfig --region ${AWS_REGION} --name ${EKS_CLUSTER_NAME}

                        # Create namespace
                        kubectl create namespace qa --dry-run=client -o yaml | kubectl apply -f -

                        # Replace placeholders and deploy
                        sed -e "s|IMAGE_PLACEHOLDER|${ECR_REGISTRY}/${ECR_REPOSITORY}:${IMAGE_TAG}|g" \
                            -e "s|BUILD_PLACEHOLDER|${BUILD_NUMBER}|g" \
                            deployment.yml | kubectl apply -f -

                        kubectl apply -f service.yml

                        # Wait for rollout
                        kubectl rollout status deployment/orderbook -n qa --timeout=3m

                        # Get service info
                        kubectl get svc -n qa orderbook-service
                    """
                }
            }
        }

        stage('Verify Deployment') {
            steps {
                withAWS(credentials: 'aws-credentials', region: 'eu-central-1') {
                    sh """
                        echo "📊 Deployment Status:"
                        kubectl get pods -n qa -l app=orderbook

                        echo -e "\n🌐 Service Details:"
                        kubectl get svc -n qa orderbook-service
                    """
                }
            }
        }
    }
}