pipeline {
    agent any

    environment {
        // AWS Configuration
        AWS_REGION = 'eu-central-1'
        EKS_CLUSTER_NAME = 'test-cluster-1'
        AWS_ACCOUNT_ID = '271758791556'
        ECR_REGISTRY = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        ECR_REPOSITORY = 'orderbook-tomcat'
        IMAGE_TAG = "${BUILD_NUMBER}"
        APP_NAME = 'orderbook'
        NAMESPACE = 'qa'
        APP_PORT = '8085'
    }

    tools {
        maven 'MAVEN_HOME'
        jdk 'JAVA_HOME'
    }

    stages {
        stage('Checkout') {
            steps {
                git url: 'https://github.com/theacademy/order-book-demo.git'
            }
        }

        stage('Build & Test') {
            parallel {
                stage('Compile') {
                    steps {
                        sh 'mvn compile'
                    }
                }

                stage('Code Review') {
                    steps {
                        sh 'mvn pmd:pmd'
                    }
                    post {
                        success {
                            recordIssues enabledForFailure: true, tool: pmdParser(pattern: '**/target/pmd.xml')
                        }
                    }
                }

                stage('Test') {
                    steps {
                        sh 'mvn test -Pcoverage'
                        sh 'mvn clover:clover clover:aggregate -Pcoverage'
                    }
                }
            }
        }

        stage('Publish Test Report') {
            steps {
                clover(
                    cloverReportDir: 'target/site/clover',
                    cloverReportFileName: 'clover.xml',
                    healthyTarget: [methodCoverage: 70, conditionalCoverage: 80, statementCoverage: 80],
                    unhealthyTarget: [methodCoverage: 50, conditionalCoverage: 50, statementCoverage: 50],
                    failingTarget: [methodCoverage: 0, conditionalCoverage: 0, statementCoverage: 0]
                )
            }
        }

        stage('Package') {
            steps {
                sh 'mvn package'
            }
        }

        stage('Docker Build & Push') {
            steps {
                withAWS(credentials: 'aws-credentials', region: "${AWS_REGION}") {
                    script {
                        sh """
                            # Login to ECR
                            aws ecr get-login-password | docker login --username AWS --password-stdin ${ECR_REGISTRY}

                            # Build Docker image
                            docker build -t ${ECR_REGISTRY}/${ECR_REPOSITORY}:${IMAGE_TAG} \
                                        -t ${ECR_REGISTRY}/${ECR_REPOSITORY}:latest .

                            # Push images to ECR
                            docker push ${ECR_REGISTRY}/${ECR_REPOSITORY}:${IMAGE_TAG}
                            docker push ${ECR_REGISTRY}/${ECR_REPOSITORY}:latest
                        """
                    }
                }
            }
        }

        stage('Deploy to EKS') {
            steps {
                withAWS(credentials: 'aws-credentials', region: "${AWS_REGION}") {
                    script {
                        sh """#!/bin/bash
                            set -e

                            echo "🚀 Deploying to EKS cluster: ${EKS_CLUSTER_NAME}"

                            # Configure kubectl
                            aws eks update-kubeconfig --region ${AWS_REGION} --name ${EKS_CLUSTER_NAME}

                            # Create namespace if not exists
                            kubectl create namespace ${NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -

                            # Create ECR pull secret (separately to avoid YAML parsing issues)
                            echo "🔑 Creating ECR pull secret..."
                            kubectl delete secret ecr-pull-secret -n ${NAMESPACE} --ignore-not-found
                            ECR_PASSWORD=\$(aws ecr get-login-password)
                            kubectl create secret docker-registry ecr-pull-secret \
                                --docker-server=${ECR_REGISTRY} \
                                --docker-username=AWS \
                                --docker-password="\${ECR_PASSWORD}" \
                                --namespace ${NAMESPACE}

                            # Create temporary deployment file
                            echo "📦 Creating deployment configuration..."
                            cat > /tmp/deployment.yaml << 'EOF'
apiVersion: apps/v1
kind: Deployment
metadata:
  name: ${APP_NAME}
  namespace: ${NAMESPACE}
  labels:
    app: ${APP_NAME}
    build: "${IMAGE_TAG}"
spec:
  replicas: 2
  selector:
    matchLabels:
      app: ${APP_NAME}
  template:
    metadata:
      labels:
        app: ${APP_NAME}
        build: "${IMAGE_TAG}"
      annotations:
        prometheus.io/scrape: "true"
        prometheus.io/port: "${APP_PORT}"
        prometheus.io/path: "/actuator/prometheus"
    spec:
      imagePullSecrets:
      - name: ecr-pull-secret
      containers:
      - name: ${APP_NAME}
        image: ${ECR_REGISTRY}/${ECR_REPOSITORY}:${IMAGE_TAG}
        ports:
        - containerPort: ${APP_PORT}
        env:
        - name: MANAGEMENT_METRICS_TAGS_APPLICATION
          value: "${APP_NAME}"
        - name: MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE
          value: "prometheus,health,info,metrics"
        - name: BUILD_NUMBER
          value: "${IMAGE_TAG}"
        - name: SPRING_PROFILES_ACTIVE
          value: "production"
        - name: SERVER_PORT
          value: "${APP_PORT}"
        - name: JAVA_OPTS
          value: "-Xmx256m -Xms128m"
        resources:
          requests:
            memory: "256Mi"
            cpu: "100m"
          limits:
            memory: "512Mi"
            cpu: "300m"
        livenessProbe:
          httpGet:
            path: /actuator/health
            port: ${APP_PORT}
          initialDelaySeconds: 60
          periodSeconds: 10
          failureThreshold: 3
        readinessProbe:
          httpGet:
            path: /actuator/health
            port: ${APP_PORT}
          initialDelaySeconds: 45
          periodSeconds: 10
          failureThreshold: 3
        startupProbe:
          httpGet:
            path: /actuator/health
            port: ${APP_PORT}
          initialDelaySeconds: 15
          periodSeconds: 5
          failureThreshold: 12
---
apiVersion: v1
kind: Service
metadata:
  name: ${APP_NAME}
  namespace: ${NAMESPACE}
  labels:
    app: ${APP_NAME}
    build: "${IMAGE_TAG}"
  annotations:
    prometheus.io/scrape: "true"
    prometheus.io/port: "${APP_PORT}"
    prometheus.io/path: "/actuator/prometheus"
spec:
  selector:
    app: ${APP_NAME}
  type: LoadBalancer
  ports:
  - name: http
    port: 80
    targetPort: ${APP_PORT}
  - name: metrics
    port: ${APP_PORT}
    targetPort: ${APP_PORT}
EOF

                            # Apply the deployment
                            echo "🚀 Applying Kubernetes manifests..."
                            kubectl apply -f /tmp/deployment.yaml

                            # Wait for rollout
                            echo "⏳ Waiting for deployment to roll out..."
                            kubectl rollout status deployment/${APP_NAME} -n ${NAMESPACE} --timeout=5m

                            # Get service information
                            echo "✅ Deployment successful!"
                            echo "📊 Service information:"
                            kubectl get svc -n ${NAMESPACE} ${APP_NAME}

                            # Get load balancer URL
                            LB_URL=\$(kubectl get svc -n ${NAMESPACE} ${APP_NAME} -o jsonpath='{.status.loadBalancer.ingress[0].hostname}' 2>/dev/null)
                            if [ -n "\$LB_URL" ]; then
                                echo "🌐 Application URL: http://\$LB_URL"
                                echo "🏥 Health check: http://\$LB_URL/actuator/health"
                                echo "📈 Metrics: http://\$LB_URL/actuator/prometheus"
                            else
                                echo "⏳ LoadBalancer provisioning in progress..."
                            fi
                        """
                    }
                }
            }
        }

        stage('Verify Deployment') {
            steps {
                withAWS(credentials: 'aws-credentials', region: "${AWS_REGION}") {
                    script {
                        sh """#!/bin/bash
                            echo "🔍 Verifying deployment..."

                            # Check pod status
                            echo "📊 Pod Status:"
                            kubectl get pods -n ${NAMESPACE} -l app=${APP_NAME}

                            # Check service
                            echo -e "\n🌐 Service Details:"
                            kubectl get svc -n ${NAMESPACE} ${APP_NAME}

                            # Check if all pods are ready
                            READY_PODS=\$(kubectl get pods -n ${NAMESPACE} -l app=${APP_NAME} | grep Running | wc -l)
                            TOTAL_PODS=\$(kubectl get pods -n ${NAMESPACE} -l app=${APP_NAME} | tail -n +2 | wc -l)

                            if [ "\$READY_PODS" -eq "\$TOTAL_PODS" ] && [ "\$TOTAL_PODS" -gt 0 ]; then
                                echo "✅ All \$TOTAL_PODS pods are running!"
                                exit 0
                            else
                                echo "❌ Only \$READY_PODS/\$TOTAL_PODS pods are ready"
                                echo "📝 Recent pod events:"
                                kubectl describe pods -n ${NAMESPACE} -l app=${APP_NAME} | grep -A10 Events
                                exit 1
                            fi
                        """
                    }
                }
            }
        }
    }

    post {
        success {
            script {
                withAWS(credentials: 'aws-credentials', region: "${AWS_REGION}") {
                    echo "✅ Pipeline completed successfully!"

                    // Get application URL
                    LB_URL = sh(
                        script: "kubectl get svc -n ${NAMESPACE} ${APP_NAME} -o jsonpath='{.status.loadBalancer.ingress[0].hostname}' 2>/dev/null || echo 'Provisioning'",
                        returnStdout: true
                    ).trim()

                    // Send notification
                    echo """
                        🎉 **DEPLOYMENT SUCCESSFUL** 🎉
                        =================================
                        Application: ${APP_NAME}
                        Version: ${IMAGE_TAG}
                        Namespace: ${NAMESPACE}
                        Cluster: ${EKS_CLUSTER_NAME}

                        📍 Application URL: http://${LB_URL}
                        🏥 Health Check: http://${LB_URL}/actuator/health
                        📈 Prometheus Metrics: http://${LB_URL}/actuator/prometheus
                        =================================
                    """
                }
            }
        }

        failure {
            script {
                withAWS(credentials: 'aws-credentials', region: "${AWS_REGION}") {
                    echo "❌ Pipeline failed! Gathering diagnostics..."

                    sh """#!/bin/bash
                        echo "🔍 **DIAGNOSTIC INFORMATION**"
                        echo "================================"

                        # Check if namespace exists
                        if kubectl get namespace ${NAMESPACE} &>/dev/null; then
                            echo "📊 Pod Status in ${NAMESPACE}:"
                            kubectl get pods -n ${NAMESPACE}

                            echo -e "\n📝 Recent Pod Events:"
                            kubectl describe pods -n ${NAMESPACE} | grep -A20 Events

                            echo -e "\n📋 Recent Logs:"
                            for pod in \$(kubectl get pods -n ${NAMESPACE} -o name | head -2); do
                                echo "--- \$pod ---"
                                kubectl logs \$pod -n ${NAMESPACE} --tail=30
                            done

                            echo -e "\n⚙️ Deployment Status:"
                            kubectl describe deployment ${APP_NAME} -n ${NAMESPACE}
                        else
                            echo "Namespace ${NAMESPACE} does not exist"
                        fi

                        echo -e "\n📦 Recent Images in ECR:"
                        aws ecr describe-images --repository-name ${ECR_REPOSITORY} --region ${AWS_REGION} \
                            --query 'imageDetails[*].{Tags:imageTags, PushedAt:imagePushedAt}' \
                            --output table | head -20

                        echo "================================"
                    """
                }
            }
        }

        always {
            echo "🧹 Cleaning up workspace..."
            cleanWs()
        }
    }
}