pipeline {
    agent any

    environment {
        // AWS Configuration
        AWS_REGION = 'eu-central-1'
        EKS_CLUSTER_NAME = 'test-cluster-1'
        AWS_ACCOUNT_ID = '271758791556'
        ECR_REGISTRY = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        ECR_REPOSITORY = 'orderbook-tomcat'
        IMAGE_TAG = "${BUILD_NUMBER}"
        APP_NAME = 'orderbook'
        NAMESPACE = 'qa'
        APP_PORT = '8085'
    }

    tools {
        maven 'MAVEN_HOME'
        jdk 'JAVA_HOME'
    }

    stages {
        stage('Checkout') {
            steps {
                git url: 'https://github.com/theacademy/order-book-demo'
            }
        }

        stage('Build & Test') {
            parallel {
                stage('Compile') {
                    steps {
                        sh 'mvn compile'
                    }
                }

                stage('Code Review') {
                    steps {
                        sh 'mvn pmd:pmd'
                    }
                    post {
                        success {
                            recordIssues enabledForFailure: true, tool: pmdParser(pattern: '**/target/pmd.xml')
                        }
                    }
                }

                stage('Test') {
                    steps {
                        sh 'mvn test -Pcoverage'
                        sh 'mvn clover:clover clover:aggregate -Pcoverage'
                    }
                }
            }
        }

        stage('Publish Test Report') {
            steps {
                clover(
                    cloverReportDir: 'target/site/clover',
                    cloverReportFileName: 'clover.xml',
                    healthyTarget: [methodCoverage: 70, conditionalCoverage: 80, statementCoverage: 80],
                    unhealthyTarget: [methodCoverage: 50, conditionalCoverage: 50, statementCoverage: 50],
                    failingTarget: [methodCoverage: 0, conditionalCoverage: 0, statementCoverage: 0]
                )
            }
        }

        stage('Package') {
            steps {
                sh 'mvn package'
            }
        }

        stage('Docker Build & Push') {
            environment {
                ECR_CREDS = credentials('aws-credentials')
            }
            steps {
                script {
                    sh """
                        # Login to ECR
                        aws ecr get-login-password --region ${AWS_REGION} | \
                            docker login --username AWS --password-stdin ${ECR_REGISTRY}

                        # Build image
                        docker build -t ${ECR_REGISTRY}/${ECR_REPOSITORY}:${IMAGE_TAG} \
                                    -t ${ECR_REGISTRY}/${ECR_REPOSITORY}:latest .

                        # Push to ECR
                        docker push ${ECR_REGISTRY}/${ECR_REPOSITORY}:${IMAGE_TAG}
                        docker push ${ECR_REGISTRY}/${ECR_REPOSITORY}:latest
                    """
                }
            }
        }

        stage('Deploy to EKS') {
            environment {
                ECR_CREDS = credentials('aws-credentials')
            }
            steps {
                script {
                    sh '''
                        #!/bin/bash
                        set -e

                        echo "🚀 Deploying to EKS cluster: ${EKS_CLUSTER_NAME}"

                        # Configure kubectl
                        aws eks update-kubeconfig --region ${AWS_REGION} --name ${EKS_CLUSTER_NAME}

                        # Create namespace if not exists
                        kubectl create namespace ${NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -

                        # Create/update ECR pull secret
                        kubectl delete secret ecr-pull-secret -n ${NAMESPACE} --ignore-not-found
                        kubectl create secret docker-registry ecr-pull-secret \
                            --docker-server=${ECR_REGISTRY} \
                            --docker-username=AWS \
                            --docker-password=$(aws ecr get-login-password) \
                            --namespace ${NAMESPACE}

                        # Deploy application - NOTE THE QUOTES AROUND ${BUILD_NUMBER}
                        echo "📦 Deploying application..."
                        cat << 'EOF' | kubectl apply -f -
        apiVersion: apps/v1
        kind: Deployment
        metadata:
          name: ${APP_NAME}
          namespace: ${NAMESPACE}
          labels:
            app: ${APP_NAME}
            build: "${BUILD_NUMBER}"  # QUOTES ARE CRITICAL
        spec:
          replicas: 2
          selector:
            matchLabels:
              app: ${APP_NAME}
          template:
            metadata:
              labels:
                app: ${APP_NAME}
                build: "${BUILD_NUMBER}"  # QUOTES ARE CRITICAL
              annotations:
                prometheus.io/scrape: "true"
                prometheus.io/port: "${APP_PORT}"
                prometheus.io/path: "/actuator/prometheus"
            spec:
              imagePullSecrets:
              - name: ecr-pull-secret
              containers:
              - name: ${APP_NAME}
                image: ${ECR_REGISTRY}/${ECR_REPOSITORY}:${IMAGE_TAG}
                ports:
                - containerPort: ${APP_PORT}
                  name: http
                env:
                - name: MANAGEMENT_METRICS_TAGS_APPLICATION
                  value: "${APP_NAME}"
                - name: MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE
                  value: "prometheus,health,info,metrics"
                - name: SPRING_PROFILES_ACTIVE
                  value: "production"
                - name: SERVER_PORT
                  value: "${APP_PORT}"
                - name: BUILD_NUMBER
                  value: "${BUILD_NUMBER}"
                resources:
                  requests:
                    memory: "256Mi"
                    cpu: "100m"
                  limits:
                    memory: "512Mi"
                    cpu: "300m"
                livenessProbe:
                  httpGet:
                    path: /actuator/health/liveness
                    port: ${APP_PORT}
                  initialDelaySeconds: 45
                  periodSeconds: 10
                  failureThreshold: 3
                readinessProbe:
                  httpGet:
                    path: /actuator/health/readiness
                    port: ${APP_PORT}
                  initialDelaySeconds: 30
                  periodSeconds: 10
                  failureThreshold: 3
                startupProbe:
                  httpGet:
                    path: /actuator/health
                    port: ${APP_PORT}
                  initialDelaySeconds: 15
                  periodSeconds: 5
                  failureThreshold: 12
        ---
        apiVersion: v1
        kind: Service
        metadata:
          name: ${APP_NAME}
          namespace: ${NAMESPACE}
          labels:
            app: ${APP_NAME}
            build: "${BUILD_NUMBER}"  # QUOTES HERE TOO
          annotations:
            prometheus.io/scrape: "true"
            prometheus.io/port: "${APP_PORT}"
            prometheus.io/path: "/actuator/prometheus"
        spec:
          selector:
            app: ${APP_NAME}
          type: LoadBalancer
          ports:
          - name: http
            port: 80
            targetPort: ${APP_PORT}
          - name: metrics
            port: ${APP_PORT}
            targetPort: ${APP_PORT}
        EOF

                        echo "⏳ Waiting for rollout to complete..."
                        kubectl rollout status deployment/${APP_NAME} -n ${NAMESPACE} --timeout=3m
                    '''
                }
            }
        }

        stage('Verify Deployment') {
            environment {
                ECR_CREDS = credentials('aws-credentials')
            }
            steps {
                script {
                    sh '''
                        #!/bin/bash
                        set -e

                        echo "🔍 Verifying deployment..."

                        # Check pod status
                        echo "📊 Pod Status:"
                        kubectl get pods -n ${NAMESPACE} -l app=${APP_NAME}

                        # Check service
                        echo -e "\n🌐 Service Details:"
                        kubectl get svc -n ${NAMESPACE} ${APP_NAME}

                        # Get application URL
                        LB_URL=$(kubectl get svc -n ${NAMESPACE} ${APP_NAME} \
                            -o jsonpath='{.status.loadBalancer.ingress[0].hostname}' 2>/dev/null)

                        if [ -n "$LB_URL" ]; then
                            echo -e "\n✅ Application is live at: http://$LB_URL"
                            echo "   Health endpoint: http://$LB_URL/actuator/health"
                            echo "   Metrics endpoint: http://$LB_URL/actuator/prometheus"

                            # Test health endpoint
                            echo -e "\n🏥 Testing health endpoint..."
                            curl -s -o /dev/null -w "Health check returned: %{http_code}\n" http://$LB_URL/actuator/health || true
                        else
                            echo "⏳ LoadBalancer still provisioning..."
                        fi
                    '''
                }
            }
        }
    }

    post {
        success {
            script {
                echo '✅ Pipeline completed successfully!'
                withAWS(credentials: 'aws-credentials', region: 'eu-central-1') {
                    LB_URL = sh(
                        script: "kubectl get svc -n ${NAMESPACE} ${APP_NAME} -o jsonpath='{.status.loadBalancer.ingress[0].hostname}' 2>/dev/null || echo 'Provisioning'",
                        returnStdout: true
                    ).trim()

                    // Send notification (customize as needed)
                    echo """
                        🎉 Deployment Successful!
                        Application: ${APP_NAME}
                        Version: ${IMAGE_TAG}
                        URL: http://${LB_URL}
                        Health: http://${LB_URL}/actuator/health
                        Metrics: http://${LB_URL}/actuator/prometheus
                        Namespace: ${NAMESPACE}
                        Cluster: ${EKS_CLUSTER_NAME}
                    """
                }
            }
        }

        failure {
            echo '❌ Pipeline failed! Running diagnostics...'
            withAWS(credentials: 'aws-credentials', region: 'eu-central-1') {
                sh '''
                    #!/bin/bash
                    echo "🔍 Gathering failure diagnostics..."

                    # Check if namespace exists
                    if kubectl get namespace ${NAMESPACE} &>/dev/null; then
                        echo -e "\n📊 Pod Status:"
                        kubectl get pods -n ${NAMESPACE} -l app=${APP_NAME}

                        echo -e "\n📝 Pod Events:"
                        kubectl describe pods -n ${NAMESPACE} -l app=${APP_NAME} | grep -A20 Events

                        echo -e "\n📋 Recent Logs:"
                        for pod in $(kubectl get pods -n ${NAMESPACE} -l app=${APP_NAME} -o name | head -1); do
                            echo "--- $pod ---"
                            kubectl logs $pod -n ${NAMESPACE} --tail=30
                        done

                        echo -e "\n⚙️ Deployment Status:"
                        kubectl describe deployment ${APP_NAME} -n ${NAMESPACE}
                    else
                        echo "Namespace ${NAMESPACE} does not exist yet."
                    fi

                    echo -e "\n📦 ECR Images:"
                    aws ecr describe-images --repository-name ${ECR_REPOSITORY} --region ${AWS_REGION} \
                        --query 'imageDetails[*].imageTags' --output table
                '''
            }
        }

        always {
            echo '🧹 Cleaning up workspace...'
            cleanWs()
        }
    }
}